{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm --filter @workspace/pest-control run build",
  "installCommand": "pnpm install --frozen-lockfile=false",
  "outputDirectory": "artifacts/pest-control/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
